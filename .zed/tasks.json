  {
    "label": "View As: Linux Debug",
    "command": "cmake",
    "args": [
      "-DSTURDY_VIEW_OS=Linux",
      "-DSTURDY_VIEW_PROFILE=Debug",
      "-P",
      ".zed/view_as_profile.cmake"
