# Per-developer CLion/JetBrains state — never shared. Everything else committed under .idea/
# (vcs.xml, codeStyles/, and any run configurations a developer chooses to share) is portable.
# Enabled CMake profiles, the active preset, window layout, and toolchains live in workspace.xml,
# which is per-machine and stays out of version control.

# Default ignored files
/shelf/
/workspace.xml
# Editor-based HTTP Client requests
/httpRequests/
# Datasource local storage ignored files
/dataSources/
/dataSources.local.xml

# User- and machine-specific settings
/usage.statistics.xml
/dictionaries/
/tasks.xml
/aws.xml
/contentModel.xml
/sonarlint/
/copilot/

# Auto-generated backend/editor state (inspection severities, indexing, discovered CMake state).
# Regenerated by CLion on open; committing it just churns per-machine noise.
/editor.xml
/misc.xml
/indexLayout.xml
/cmake.xml
/.name
/modules.xml
