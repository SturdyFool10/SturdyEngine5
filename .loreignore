# Lore metadata
.lore/

# Git metadata
.git/

# Agent coordination metadata
agent_collaboration.md

# Architecture/design-doc scratch space (see plans/README.md) — working notes, not shipped docs.
/plans/

# Build directories
build/
out/

# Local build/tooling caches: clangd index and the shared FetchContent dependency source cache
# (STURDY_SHARED_DEPS_CACHE). Mirrors /.cache/ in .gitignore.
/.cache/

# Claude Code local settings (machine-specific tool permissions, not shared repo state).
.claude/

# Upstream dependency licenses, copied in from each FetchContent source tree at build time
# (see cmake/SturdyLicenses.cmake). Regenerated content, not tracked.
/thirdparty/licenses/

# CMake generated files and directories
**/CMakeFiles/
**/CMakeCache.txt
**/CMakeConfigureLog.yaml
**/cmake_install.cmake
**/install_manifest.txt
**/CTestTestfile.cmake
**/CPackConfig.cmake
**/CPackSourceConfig.cmake
**/Makefile
**/build.ninja
**/.ninja_deps
**/.ninja_log
**/Testing/

# CMake FetchContent and external dependency build trees
**/_deps/
**/*-build/
**/*-subbuild/
**/*-populate-prefix/

# Compiler and linker outputs
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe
*.pdb
*.ilk
*.d
*.gcda
*.gcno
*.gcov

# Runtime dumps and logs
*.log
*.dmp
*.core
